{
  "enabled": true,
  "name": "cfn-lint on save",
  "description": "template.yaml 保存時に cfn-lint を自動実行してエラーを即座にフィードバック",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": ["**/template.yaml"]
  },
  "then": {
    "type": "askAgent",
    "prompt": "編集中の template.yaml を cfn-lint で検証してください。エラーや警告があれば内容・行番号・修正方法を日本語で報告してください。問題がなければその旨を日本語で報告してください。"
  }
}
