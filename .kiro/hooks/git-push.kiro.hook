{
  "enabled": true,
  "name": "commit and push",
  "description": "変更をコミット＆プッシュしてパイプラインをキック",
  "version": "1",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "askAgent",
    "prompt": "pattern-3/template.yaml の変更内容を確認し、適切なコミットメッセージを生成してgit commit & pushしてください。pushが完了したらCodePipelineが自動起動することを伝えてください。"
  }
}
